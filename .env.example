# Server
PORT=3000
NODE_ENV=development

# Supabase (server uses service role; anon key optional for client-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Legacy fallback (not recommended for production)
# SUPABASE_ANON_KEY=your-anon-key

# API authentication (required in production)
API_KEY=your-secret-api-key

# WhatsApp / Gupshup
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_SOURCE_PHONE=917386901879

# Webhook verification (both required in production)
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WEBHOOK_SECRET=your-webhook-hmac-secret

# CORS (comma-separated origins; empty = same-origin only in production)
CORS_ORIGINS=http://localhost:3000

# Rate limits (requests per minute)
API_RATE_LIMIT_PER_MINUTE=120
WEBHOOK_RATE_LIMIT_PER_MINUTE=300

# Reminder worker
REMINDER_CRON_SCHEDULE=0 9,21 * * *
REMINDER_TIMEZONE=Asia/Kolkata
REMINDER_CATCH_UP_DAYS=7
REMINDER_LOOKAHEAD_DAYS=1

# Optional error tracking
# SENTRY_DSN=
